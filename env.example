# =============================================================================
# 📋 FICHIER .ENV.EXAMPLE - Configuration du site CAM
# =============================================================================
# -----------------------------------------------------------------------------
# Copier ce fichier en ".env"
# puis remplacer chaque valeur par les vraies informations du projet.
#
# ⚠️ IMPORTANT :
# - Ne jamais commit le vrai fichier .env
# - Ne jamais partager les mots de passe SMTP ou clés API
# - Toutes les variables commençant par NEXT_PUBLIC_ sont visibles côté navigateur
# -----------------------------------------------------------------------------

# =============================================================================
# 🔗 AUTODOC - Programme de parrainage
# =============================================================================
# Code de parrainage affiché sur le site
NEXT_PUBLIC_AUTODOC_REF_CODE=votre-code-parrainage

# URL du programme de parrainage AUTODOC
NEXT_PUBLIC_AUTODOC_REF_URL=https://www.auto-doc.fr/

# =============================================================================
# 🌐 INFORMATIONS GÉNÉRALES DU SITE
# =============================================================================
# Utilisées dans :
# - SEO
# - metadata.ts
# - footer
# - pages de contact
# - mentions légales

# Nom du site / entreprise
NEXT_PUBLIC_SITE_NAME=Nom du site

# Description SEO principale
NEXT_PUBLIC_SITE_DESCRIPTION=Description du site

# URL principale du site (production)
NEXT_PUBLIC_SITE_URL=https://votre-site.com

# Téléphone affiché sur le site
NEXT_PUBLIC_SITE_PHONE=+33 6 00 00 00 00

# Email public affiché sur le site
NEXT_PUBLIC_SITE_EMAIL=contact@votre-site.com

# =============================================================================
# 📍 LOCALISATION
# =============================================================================
# Ville principale d'intervention
NEXT_PUBLIC_CITY=Ville

# Rayon d'intervention en kilomètres
NEXT_PUBLIC_RAYON_INTERVENTION=40

# Adresse légale affichée dans les mentions légales
# Peut être masquée pour micro-entreprise si nécessaire
NEXT_PUBLIC_SITE_ADDRESS=Adresse ou mention légale

# =============================================================================
# ⚖️ INFORMATIONS LÉGALES
# =============================================================================
# Numéro SIRET de l'entreprise
NEXT_PUBLIC_SIRET=00000000000000

# Nom du propriétaire / gérant
NEXT_PUBLIC_OWNER_NAME=Nom du propriétaire

# =============================================================================
# 📅 CAL.COM - SYSTÈME DE RÉSERVATION
# =============================================================================
# Username Cal.com
NEXT_PUBLIC_CAL_COM_USERNAME=votre-username

# URL d'intégration du formulaire Cal.com
# Exemple :
# forms/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_CAL_COM_URL=forms/votre-form-id

# =============================================================================
# 💬 WHATSAPP
# =============================================================================
# Numéro WhatsApp au format international sans "+"
# Exemple :
# 33600000000
NEXT_PUBLIC_WHATSAPP_NUMBER=33600000000

# =============================================================================
# 📧 CONFIGURATION SMTP (NODEMAILER)
# =============================================================================
# Utilisées pour :
# - formulaire de contact
# - envoi d'emails automatiques
#
# ⚠️ IMPORTANT :
# Ces variables sont PRIVÉES.
# Ne jamais les exposer publiquement.

# Serveur SMTP
SMTP_HOST=smtp.hostinger.com

# Port SMTP
# 465 = SSL

SMTP_PORT=465

# Adresse email SMTP
SMTP_USER=contact@votre-domaine.fr

# Mot de passe SMTP
SMTP_PASS=votre-mot-de-passe-smtp

# Expéditeur affiché dans les emails
SMTP_FROM=NomDuGarage <contact@votre-domaine.fr>

# Adresse qui reçoit les formulaires de contact
CONTACT_RECEIVER=votre-email@exemple.fr

# =============================================================================
# 🔒 ADMIN - CRM privé (/admin)
# =============================================================================
# Mot de passe unique pour accéder au tableau de bord privé
ADMIN_PASSWORD=change-moi

# Chaîne aléatoire longue utilisée pour signer les sessions (générer avec
# `openssl rand -base64 32` par exemple)
ADMIN_SESSION_SECRET=generer-une-chaine-aleatoire-longue

# =============================================================================
# 💶 SYNCHRO FINANCE COPILOT (app perso, optionnel)
# =============================================================================
# Clé partagée permettant à l'app Finance Copilot (locale) d'appeler
# /api/finance-sync pour récupérer les encaissements espèces. Générer avec
# `openssl rand -base64 32` par exemple.
FINANCE_SYNC_API_KEY=generer-une-chaine-aleatoire-longue

# =============================================================================
# 🗄️ BASE DE DONNÉES (Vercel Postgres)
# =============================================================================
# Fournies automatiquement en attachant l'intégration Vercel Postgres au projet
DATABASE_URL=postgres://...
DATABASE_URL_UNPOOLED=postgres://...

# =============================================================================
# 🔩 STOCK - Identification IA des pièces (Gemini, gratuit)
# =============================================================================
# Clé API Google Gemini, utilisée par /admin/stock pour identifier une pièce
# à partir de photos. https://aistudio.google.com/apikey
GEMINI_API_KEY=votre-cle-gemini